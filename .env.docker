# Variabili per servizi Docker Compose (committato — nessun segreto reale)
NODE_ENV=development
PORT=3000

MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=solartracking
MYSQL_PASSWORD=solartracking_pwd
MYSQL_DATABASE=solar_tracking
MYSQL_ROOT_PASSWORD=root_pwd

SOLARMAN_API_URL=https://globalapi.solarmanpv.com
SOLARMAN_APP_ID=
SOLARMAN_APP_SECRET=
SOLARMAN_EMAIL=
SOLARMAN_PASSWORD=
SOLARMAN_STATION_ID=

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

LLM_ENDPOINT=http://llm:8080
LLM_MODEL=openllama-3b

CUBBIT_ACCESS_KEY_ID=
CUBBIT_SECRET_ACCESS_KEY=
CUBBIT_ENDPOINT=s3.cubbit.eu
CUBBIT_REGION=eu-west-1
CUBBIT_BUCKET=solar-tracking-app
CUBBIT_BACKUP_PREFIX=backups
CUBBIT_ARCHIVE_PREFIX=archive
