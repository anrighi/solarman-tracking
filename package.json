{
  "name": "solar-tracking",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "sync:once": "tsx --env-file=.env scripts/sync-once.ts",
    "sync:backfill": "tsx --env-file=.env scripts/sync-backfill.ts",
    "sync:backfill:full": "tsx --env-file=.env scripts/backfill-full.ts",
    "sync:worker": "tsx --env-file=.env scripts/sync-worker.ts",
    "compare:totals": "tsx --env-file=.env scripts/compare-energy-totals.ts",
    "db:dedupe-samples": "tsx --env-file=.env scripts/dedupe-energy-samples.ts",
    "db:dump": "tsx --env-file=.env scripts/db-dump.ts",
    "db:restore": "tsx --env-file=.env scripts/db-restore.ts",
    "db:restore:test": "tsx --env-file=.env scripts/backup-restore-test.ts",
    "backup:run": "tsx --env-file=.env scripts/backup-run.ts manual"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/router-plugin": "^1.132.0",
    "lucide-react": "^0.545.0",
    "mysql2": "^3.22.5",
    "nitro": "npm:nitro-nightly@latest",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "recharts": "^3.9.1",
    "tailwindcss": "^4.1.18",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@tanstack/devtools-vite": "latest",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.2",
    "vite": "^8.0.0",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  }
}