# === App ===
NODE_ENV=development
PORT=3000

# === MySQL ===
# Docker Compose: usa .env.docker (MYSQL_HOST=mysql)
# Dev locale: copia .env.local.example → .env.local (MYSQL_HOST=127.0.0.1)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=solartracking
MYSQL_PASSWORD=solartracking_pwd
MYSQL_DATABASE=solar_tracking
MYSQL_ROOT_PASSWORD=root_pwd

# === Solarman API (Phase 1) ===
SOLARMAN_API_URL=https://globalapi.solarmanpv.com
SOLARMAN_APP_ID=
SOLARMAN_APP_SECRET=
SOLARMAN_EMAIL=
SOLARMAN_PASSWORD=
SOLARMAN_STATION_ID=

# === Backup (Cubbit DS3 via rclone) ===
CUBBIT_ACCESS_KEY_ID=
CUBBIT_SECRET_ACCESS_KEY=
CUBBIT_ENDPOINT=s3.cubbit.eu
CUBBIT_REGION=eu-west-1
CUBBIT_BUCKET=solar-tracking-app
CUBBIT_BACKUP_PREFIX=backups
BACKUP_SCHEDULE_TZ=Europe/Rome
BACKUP_SCHEDULE_HOUR=3
BACKUP_RETENTION_DAYS_LOCAL=7
BACKUP_RETENTION_DAYS_REMOTE=30
# RCLONE_REMOTE=cubbit:solar-tracking-app/backups

# === Telegram (Phase 3) ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# === LLM (Phase 3) ===
LLM_ENDPOINT=http://llm:8080
LLM_MODEL=openllama-3b
