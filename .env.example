# === App ===
NODE_ENV=development
PORT=3000

# === MySQL ===
# Docker Compose: usa .env.docker (MYSQL_HOST=mysql)
# Dev locale: copia .env.local.example → .env.local (MYSQL_HOST=127.0.0.1)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=solartracking
MYSQL_PASSWORD=solartracking_pwd
MYSQL_DATABASE=solar_tracking
MYSQL_ROOT_PASSWORD=root_pwd

# === Solarman API (Phase 1) ===
SOLARMAN_API_URL=https://globalapi.solarmanpv.com
SOLARMAN_APP_ID=
SOLARMAN_APP_SECRET=
SOLARMAN_EMAIL=
SOLARMAN_PASSWORD=
SOLARMAN_STATION_ID=

# === Telegram (Phase 3) ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# === LLM (Phase 3) ===
LLM_ENDPOINT=http://llm:8080
LLM_MODEL=openllama-3b
